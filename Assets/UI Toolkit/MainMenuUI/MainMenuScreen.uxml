<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/MainMenuUI/MainMenuStyle.uss?fileID=7433441132597879392&amp;guid=f6c2c2c987a83e147985532b90570bfc&amp;type=3#MainMenuStyle"/>
    <ui:VisualElement name="MainMenuContainer" enabled="true" style="flex-grow: 1;">
        <ui:Button text="Start Game" name="StartGameButton" class="button" style="width: 220px; height: 60px; align-items: stretch; align-self: center; align-content: auto; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; border-top-width: 4px; border-right-width: 4px; border-bottom-width: 4px; border-left-width: 4px; border-left-color: rgb(255, 211, 0); border-right-color: rgb(255, 211, 0); border-top-color: rgb(255, 211, 0); border-bottom-color: rgb(255, 211, 0); background-color: rgb(138, 111, 59);"/>
        <ui:Button text="Options" name="OptionsButton" class="button" style="width: 220px; height: 60px; align-items: stretch; align-self: center; align-content: auto; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; border-top-width: 4px; border-right-width: 4px; border-bottom-width: 4px; border-left-width: 4px; border-left-color: rgb(247, 204, 5); border-right-color: rgb(247, 204, 5); border-top-color: rgb(247, 204, 5); border-bottom-color: rgb(247, 204, 5); background-color: rgb(138, 111, 59);"/>
        <ui:Button text="Quit" name="QuitButton" enabled="true" class="button" style="width: 220px; height: 60px; align-items: stretch; align-self: center; align-content: auto; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; border-top-width: 4px; border-right-width: 4px; border-bottom-width: 4px; border-left-width: 4px; border-left-color: rgb(247, 204, 5); border-right-color: rgb(247, 204, 5); border-top-color: rgb(247, 204, 5); border-bottom-color: rgb(247, 204, 5); background-color: rgb(138, 111, 59);"/>
        <ui:Button text="Credits " name="CreditsButton" enabled="true" class="button" style="width: 220px; height: 60px; align-items: auto; align-self: flex-start; align-content: auto; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; border-top-width: 4px; border-right-width: 4px; border-bottom-width: 4px; border-left-width: 4px; border-left-color: rgb(247, 204, 5); border-right-color: rgb(247, 204, 5); border-top-color: rgb(247, 204, 5); border-bottom-color: rgb(247, 204, 5); white-space: nowrap; right: 0; top: 510px; justify-content: center; background-color: rgb(138, 111, 59);"/>
    </ui:VisualElement>
</ui:UXML>
